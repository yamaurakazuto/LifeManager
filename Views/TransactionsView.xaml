<Window x:Class="LifeManager.Views.TransactionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LifeManager.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Title="TransactionsView" Height="500" Width="800" Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Background="#0F172A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>  
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        
        <Border 
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="0"
            Grid.RowSpan="4"
            Background="#1E293B"
            CornerRadius="12"
            Padding="20"
            Margin="20"
      >

            <StackPanel>

                <!-- 日付 -->
                <TextBlock Text="日付"
                   Foreground="White"
                   FontSize="20"
                   Margin="0,0,0,8"/>

                <DatePicker
            SelectedDate="{Binding SelectedDate}"
            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
            materialDesign:HintAssist.Hint="日付を選択"
                   Foreground="White"
            Margin="0,0,0,20"/>



                <TextBlock Text="収入"
                            FontSize="20"
                            Foreground="White"/>

                <TextBox 
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding Income, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                    PreviewTextInput="NumberOnly_PreviewTextInput"   
                    DataObject.Pasting="NumberOnly_Pasting"
                    Height="50"
                    Margin="0,5,0,15"
                    materialDesign:HintAssist.Hint="収入"
                    BorderBrush="White"
                    BorderThickness="1.5"
                    Foreground="White"/>

                <TextBlock Text="支出"
                            FontSize="20"
                            Foreground="White"/>

                <TextBox 
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding Expense, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                    PreviewTextInput="NumberOnly_PreviewTextInput"   
                    DataObject.Pasting="NumberOnly_Pasting"
                    Height="50"
                    Margin="0,5,0,15"
                    materialDesign:HintAssist.Hint="支出"
                    BorderBrush="White"
                    BorderThickness="1.5"
                    Foreground="White"/>

            </StackPanel>
        </Border>
        
        <!-- ボタン -->
            <Button Content="表示"
                    Margin="0,10,0,10"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Grid.Column="2"
                    Grid.Row="3"
                    Grid.ColumnSpan="2"/>

            <!-- 一覧 -->
        <DataGrid ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False"
                      Background="LightBlue"
                      Height="300"
                      Grid.Column="2"
                      Grid.Row="0"
                      Grid.ColumnSpan="2"
                      Grid.RowSpan="3"/>    

        <!-- 合計 -->
        <Border
            Grid.Column="0"
            Grid.Row="4"
            Grid.ColumnSpan="2"
            BorderBrush="White"
            BorderThickness="1.5"      
            Background="#1E293B"
            CornerRadius="12"
            Padding="10"
            Margin="20"
            >

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
            

               <!-- 合計ラベル -->
        <TextBlock Text="合計"
                   Foreground="White"
                   FontSize="18"
                   VerticalAlignment="Center"/>


                <TextBlock Text="{Binding Total, StringFormat='{}{0:N0}円'}"
           Foreground="White"
           FontSize="20"
           Margin="0,10,0,0" 
           Grid.Column="1"    
           VerticalAlignment="Center"
           />
            </Grid>
        </Border>
            
       
    </Grid>
</Window>
