<Window x:Class="LifeManager.Views.TransactionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LifeManager.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Title="TransactionsView" Height="450" Width="800" Background="{DynamicResource MaterialDesignPaper}">
    <Grid Background="#12121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        

            <!-- 日付 -->
            <DatePicker SelectedDate="{Binding SelectedDate}" />
        
            <!--収入-->
            <TextBlock Text="収入" 
                       FontSize="20" 
                       Foreground="White"
                       Margin="0,10,0,0" 
                       Grid.Column="0"
                       Grid.Row="1"/>

        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                  Width="100"
                 Height="60"
                 materialDesign:HintAssist.Hint="金額"
                 BorderBrush="White"
                 BorderThickness="2"
                 Margin="5"
                 Grid.Column="1" 
                     Grid.Row="1"
                     />
        <!--支出-->
            <TextBlock Text="支出" 
                       FontSize="20" 
                       Foreground="White"
                       Margin="0,10,0,0" 
                       Grid.Column="0"
                       Grid.Row="2"/>

        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
          Width="100"
         Height="60"
         BorderBrush="White"
         BorderThickness="2"
         Margin="5"
         Grid.Column="1" 
             Grid.Row="2"
             />

        <!-- ボタン -->
            <Button Content="表示"
                    Margin="0,10,0,10"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Grid.Column="2"
                    Grid.Row="3"
                    Grid.ColumnSpan="2"/>

            <!-- 一覧 -->
        <DataGrid ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False"
                      Background="LightBlue"
                      Height="300"
                      Grid.Column="2"
                      Grid.Row="0"
                      Grid.ColumnSpan="2"
                      Grid.RowSpan="3"/>    

        <!-- 合計 -->
            <TextBlock Text="{Binding Total}"
                       FontSize="20"
                       Margin="0,10,0,0" 
                       Grid.Column="2"
                       Grid.Row="4"
                       Grid.ColumnSpan="2"
                       Background="LightGray"/> 
       
    </Grid>
</Window>
