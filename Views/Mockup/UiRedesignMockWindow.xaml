<Window x:Class="LifeManager.Views.Mockup.UiRedesignMockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LifeManager.Views.Mockup"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="UI直感操作リデザイン案（モック）" Height="660" Width="1120"
        Background="#0B1120">

    <!-- デザイン確認用の静的モック。値はハードコードで、実データにはバインドしていない。
         既存ダークパレット（#0F172A / #1E293B ＋ Teal / Violet）を踏襲し、
         収入=ティール／支出=ローズで役割を色分けする案。 -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="LifeManager UI モック — 直感操作リデザイン案"
                       Foreground="#F1F5F9" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,4,0,0"
                       Text="収入=ティール／支出=ローズで色分け。合計は符号で色が変わる。日付→収入→支出→合計→保存を上から一直線に。"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3">

            <!-- ホーム -->
            <Border Background="#0F172A" CornerRadius="16" BorderBrush="#475569" BorderThickness="1"
                    Margin="0,0,10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="ホーム" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock Text="今日はなにをする？" Foreground="#F1F5F9" FontSize="18"
                               FontWeight="SemiBold" Margin="0,4,0,16"/>

                    <!-- 収支をつける -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Background="#0F766E" Foreground="#F1F5F9"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Height="76" HorizontalContentAlignment="Left" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#2DD4BF" CornerRadius="12" Width="44" Height="44"
                                    VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"
                                                         Foreground="#04342C"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="収支をつける" Foreground="#F1F5F9" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="収入・支出を入力" Foreground="#5DCAA5" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- 履歴をみる -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Background="#3C3489" Foreground="#F1F5F9"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Height="76" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#A78BFA" CornerRadius="12" Width="44" Height="44"
                                    VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="History" Width="24" Height="24"
                                                         Foreground="#26215C"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="履歴をみる" Foreground="#F1F5F9" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="過去の記録を確認" Foreground="#CECBF6" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 収支入力 -->
            <Border Background="#0F172A" CornerRadius="16" BorderBrush="#475569" BorderThickness="1"
                    Margin="10,0,10,0" Padding="20">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="収支をつける" Foreground="#F1F5F9" FontSize="16"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Background="#1E293B" CornerRadius="999" Padding="10,6"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Calendar" Width="15" Height="15"
                                                         Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                <TextBlock Text="7/14" Foreground="#F1F5F9" FontSize="13" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 収入 -->
                    <Border Background="#1E293B" CornerRadius="0,12,12,0" BorderBrush="#2DD4BF"
                            BorderThickness="4,0,0,0" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowBottomLeft" Width="16" Height="16"
                                                         Foreground="#5DCAA5" VerticalAlignment="Center"/>
                                <TextBlock Text="収入" Foreground="#5DCAA5" FontSize="13" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                <TextBlock Text="120,000" Foreground="#2DD4BF" FontSize="26" FontWeight="SemiBold"/>
                                <TextBlock Text="円" Foreground="#94A3B8" FontSize="14" Margin="4,0,0,4" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 支出 -->
                    <Border Background="#1E293B" CornerRadius="0,12,12,0" BorderBrush="#FB7185"
                            BorderThickness="4,0,0,0" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowTopRight" Width="16" Height="16"
                                                         Foreground="#F4A0B0" VerticalAlignment="Center"/>
                                <TextBlock Text="支出" Foreground="#F4A0B0" FontSize="13" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                <TextBlock Text="45,000" Foreground="#FB7185" FontSize="26" FontWeight="SemiBold"/>
                                <TextBlock Text="円" Foreground="#94A3B8" FontSize="14" Margin="4,0,0,4" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 合計 -->
                    <Border Background="#052E2B" CornerRadius="12" BorderBrush="#0F766E"
                            BorderThickness="1" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <TextBlock Text="合計" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="+75,000 円" Foreground="#2DD4BF" FontSize="24" FontWeight="SemiBold"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 保存 -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="#FFFFFF"
                            materialDesign:ButtonAssist.CornerRadius="12" Height="48">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="保存する" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 収支履歴 -->
            <Border Background="#0F172A" CornerRadius="16" BorderBrush="#475569" BorderThickness="1"
                    Margin="10,0,0,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="収支履歴" Foreground="#F1F5F9" FontSize="16"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="日付" Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="金額" Foreground="#94A3B8" FontSize="13"/>
                    </Grid>
                    <Border Height="1" Background="#475569" Margin="0,0,0,4"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="7/14" Foreground="#F1F5F9" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="+75,000" Foreground="#2DD4BF" FontSize="14"/>
                    </Grid>
                    <Border Height="1" Background="#24324A"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="7/13" Foreground="#F1F5F9" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="−12,300" Foreground="#FB7185" FontSize="14"/>
                    </Grid>
                    <Border Height="1" Background="#24324A"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="7/12" Foreground="#F1F5F9" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="+8,000" Foreground="#2DD4BF" FontSize="14"/>
                    </Grid>
                    <Border Height="1" Background="#24324A"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="7/11" Foreground="#F1F5F9" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="−4,500" Foreground="#FB7185" FontSize="14"/>
                    </Grid>
                    <Border Height="1" Background="#24324A"/>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</Window>
